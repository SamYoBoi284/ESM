rules_version = '2';

// ===========================================
// RelayDesk
// storage.rules
// Firebase Storage — chat image attachments
// ===========================================
//
// Same reasoning as firestore.rules: this app has no Firebase Auth
// layer of its own (login is a custom employee-code + PIN flow
// checked against the "users" Firestore collection), so there's no
// request.auth to key off of here. Scoped open, time-boxed the same
// way as the Firestore catch-all, so it keeps working until a real
// auth solution is added. Tighten alongside that when it lands.
service firebase.storage {
  match /b/{bucket}/o {

    // Chat image attachments (chat.js) — one object per message, at
    // chatImages/{chatId}/{messageId}.{ext}. Firestore only ever
    // stores the resulting download URL; the bytes live here.
    match /chatImages/{chatId}/{fileName} {
      allow read, write: if request.time < timestamp.date(2026, 7, 30);
    }
  }
}
