{
  "name": "ESM",
  "version": "4.4.0",
  "buildDate": "2026-07-12",
  "description": "Employee Status Monitor, or ESM for short, is our app-to-go for organizing our operations and keeping communication flowing. It is a simple, yet effective tool that allows the users to simplify daily tasks that were daunting and time-consuming.",
  "author": "Sam",
  "main": "electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/SamYoBoi284/ESM.git"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never",
    "dist": "electron-builder --publish never",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "release:force": "node scripts/release.js --force"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^26.0.0"
  },
  "allowScripts": {
    "electron@34.5.8": true,
    "electron-winstaller@5.4.0": true
  }
}
