rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // This rule allows anyone with your Firestore database reference to view, edit,
    // and delete all data in your Firestore database. It is useful for getting
    // started, but it is configured to expire after 30 days because it
    // leaves your app open to attackers. At that time, all client
    // requests to your Firestore database will be denied.
    //
    // Make sure to write security rules for your app before that time, or else
    // all client requests to your Firestore database will be denied until you Update
    // your rules
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 7, 30);
    }

    // ===========================================
    // FEEDBACK / FEATURE REQUEST SYSTEM (added with the Batch 1+2
    // rollout). This app has no Firebase Auth layer of its own (login
    // is a custom employee-code + PIN flow checked against the
    // "users" collection), so there's no request.auth to key off of
    // here — this rule is scoped identically to the catch-all above
    // (open) so nothing changes in practice today, but it keeps this
    // collection working once the catch-all's July 30, 2026 expiry
    // hits. Tighten this alongside a real auth solution if/when one
    // gets added.
    match /featureRequests/{requestId} {
      allow read, write: if true;
    }

    // ===========================================
    // VIOLATIONS LOG (violations.js) + shared "system" config docs
    // (also used by monthlystats.js's GitHub backup config). Same
    // reasoning as featureRequests above — scoped identically to the
    // catch-all (open) for now so nothing changes in practice today,
    // but these keep working past the catch-all's July 30, 2026
    // expiry. Tighten alongside a real auth solution if/when one
    // gets added.
    // ===========================================
    match /violationLogs/{logId} {
      allow read, write: if true;
    }
    match /violationsArchive/{month} {
      allow read, write: if true;
    }
    match /system/{docId} {
      allow read, write: if true;
    }

    // ===========================================
    // SHIFT MANAGEMENT (shiftmanagement.js) — the new configurable,
    // Firestore-backed shift system. Same reasoning as the other
    // collections above: no Firebase Auth in this app (custom
    // employee-code + PIN login checked against "users"), so this is
    // scoped identically to the catch-all (open) for now, but keeps
    // working past the catch-all's July 30, 2026 expiry. Tighten
    // alongside a real auth solution if/when one gets added.
    // ===========================================
    match /shifts/{shiftId} {
      allow read, write: if true;
    }

    // ===========================================
    // NOTIFICATION CENTER (notificationcenter.js, Phase 1) — persistent
    // per-user notification history. Same reasoning as the other
    // collections above: no Firebase Auth in this app, so scoped
    // identically to the catch-all (open) for now, but keeps working
    // past the catch-all's July 30, 2026 expiry.
    // ===========================================
    match /notificationHistory/{entryId} {
      allow read, write: if true;
    }
  }
}